# =====================================================
# Dashboard Miranda Studio — exemplo de variáveis
# Copie este arquivo para .env.local e preencha.
# NUNCA commitar .env.local.
# =====================================================

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Conta Azul (OAuth 2.0) ---
CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=
CONTA_AZUL_REDIRECT_URI=
CONTA_AZUL_REFRESH_TOKEN=

# --- Nuvemshop ---
NUVEMSHOP_STORE_ID=
NUVEMSHOP_ACCESS_TOKEN=
NUVEMSHOP_USER_AGENT=MirandaStudioDashboard (contato@mirandaestudio.com.br)

# --- Meta Ads (Marketing API) ---
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_BUSINESS_ID=
META_API_VERSION=v19.0

# --- Dashboard ---
DASHBOARD_TIMEZONE=America/Sao_Paulo
