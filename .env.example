# =====================================================
# Dashboard Miranda Studio — exemplo de variáveis
# Copie este arquivo para .env.local e preencha.
# NUNCA commitar .env.local.
# =====================================================

# --- Supabase ---
SUPABASE_URL=
# Not used by the app — all access uses service_role
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Conta Azul (OAuth 2.0) ---
CONTA_AZUL_CLIENT_ID=
CONTA_AZUL_CLIENT_SECRET=
# Only needed for manual OAuth token generation, not runtime
CONTA_AZUL_REDIRECT_URI=
CONTA_AZUL_REFRESH_TOKEN=

# --- Nuvemshop ---
NUVEMSHOP_STORE_ID=
NUVEMSHOP_ACCESS_TOKEN=
NUVEMSHOP_USER_AGENT=MirandaStudioDashboard (contato@mirandaestudio.com.br)
# Client secret da app Nuvemshop — usado para validacao HMAC nos webhooks LGPD.
# Sem este secret, os 3 endpoints LGPD rejeitam todas as requisicoes com 401.
NUVEMSHOP_CLIENT_SECRET=

# --- Meta Ads (Marketing API) ---
# App ID do app Marketing criado em developers.facebook.com (semi-publico)
META_APP_ID=
# App Secret — rotacionar antes de producao real (T47)
META_APP_SECRET=
# System User Token gerado no Business Manager da Miranda.
# Nao expira (set_token_expires_in_60_days=false). Scopes: ads_read + business_management.
# Rotacionar antes de producao real (T47).
META_SYSTEM_USER_TOKEN=
# Ad Account ID com prefixo "act_" (IMPORTANTE — sem o prefixo o client quebra).
META_AD_ACCOUNT_ID=act_YOUR_AD_ACCOUNT_ID
# Business Manager ID da Miranda.
META_BUSINESS_ID=YOUR_BUSINESS_MANAGER_ID
# Graph API version — travada em v25.0 por decisao (ver DECISOES 2026-04-10 D5).
META_API_VERSION=v25.0

# --- Dashboard ---
# Hardcoded in code as 'America/Sao_Paulo' — this var is not read
DASHBOARD_TIMEZONE=America/Sao_Paulo
DASHBOARD_LOGIN=
DASHBOARD_PASSWORD=
# Secret para assinar tokens de sessao (HMAC-SHA256). Gerar com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
