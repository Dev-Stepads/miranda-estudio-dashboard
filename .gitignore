# Dependencies
node_modules/
.pnp/
.pnp.js

# Environment — NUNCA commitar credenciais
.env
.env.local
.env.*.local
.env.development
.env.production

# Rascunhos locais e "cofres" que NÃO são o cofre oficial — NUNCA commitar
# (regra defensiva: evita que um arquivo de nome arbitrário com credenciais
# acabe no Git. O cofre oficial é o 1Password/Bitwarden da Stepads,
# NUNCA um arquivo local.)
cofre.*
secrets.*
credentials.*
scratch.*
notes.local.*
/onde*.txt
/onde*.yaml
/onde*.yml
/onde*.md
/onde*.0

# Build (Next.js + general)
.next/
*.tsbuildinfo
dist/
build/
out/
next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Cache
.cache/
.turbo/
.vercel/

# Supabase local
supabase/.branches
supabase/.temp

# Screenshots de investigação do dashboard real da Miranda — PII
# Contêm dados sensíveis (CPF, faturamento, clientes). NUNCA commitar.
debug_screenshots/
/Captura de tela*.jpg
/Captura de tela*.jpeg
/Captura de tela*.png

# Pastas de prints/screenshots gerais — defensivo. Mesmo motivo dos debug_screenshots.
# Captura recebida em qualquer subpasta cai aqui.
prints*/
screenshots*/
**/Captura de tela*.jpg
**/Captura de tela*.jpeg
**/Captura de tela*.png

# Arquivos .ini — credenciais (ex: chaves conta azul.ini)
*.ini

# Debug scripts locais
browser_debug.js

# Imagens soltas no root — defensivo.
# Bloqueia qualquer .jpg/.jpeg/.png/.gif no diretório raiz do projeto pra
# evitar que prints de portais (Conta Azul, Nuvemshop, Meta) com credenciais,
# CNPJ ou dados sensíveis acabem comitados acidentalmente. Imagens
# legítimas (logo, mockups, etc.) devem ficar em /public, /assets ou
# subpasta dedicada — não no root.
/*.jpg
/*.jpeg
/*.png
/*.gif
/*.webp
.vercel
