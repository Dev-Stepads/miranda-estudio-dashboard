{
  "name": "miranda---stepads",
  "version": "1.0.0",
  "description": "Dashboard consolidado da Miranda Studio com três origens de dados: Conta Azul, Nuvemshop e Meta Ads",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc",
    "sync:nuvemshop": "tsx --env-file=.env.local src/etl/nuvemshop/run.ts",
    "sync:nuvemshop:full": "tsx --env-file=.env.local src/etl/nuvemshop/run.ts --full",
    "sync:contaazul": "tsx --env-file=.env.local src/etl/conta-azul/run.ts",
    "sync:contaazul:full": "tsx --env-file=.env.local src/etl/conta-azul/run.ts --full",
    "sync:meta-ads": "tsx --env-file=.env.local src/etl/meta-ads/run.ts",
    "sync:meta-ads:full": "tsx --env-file=.env.local src/etl/meta-ads/run.ts --full"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dev-Stepads/miranda-estudio-dashboard.git"
  },
  "keywords": [],
  "author": "Stepads",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Dev-Stepads/miranda-estudio-dashboard/issues"
  },
  "homepage": "https://github.com/Dev-Stepads/miranda-estudio-dashboard#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "fast-xml-parser": "^5.5.11",
    "next": "^16.2.3",
    "playwright-core": "^1.59.1",
    "prop-types": "^15.8.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.5",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "msw": "^2.7.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
